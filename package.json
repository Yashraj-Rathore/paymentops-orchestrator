{
  "name": "paymentops-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Payment operations platform simulator with NestJS, Nuxt, SQL Server, Redis, and Redpanda.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "js-yaml": "4.2.0",
      "lodash": "4.18.0",
      "multer": "2.2.0",
      "qs": "6.15.2"
    }
  },
  "scripts": {
    "build:packages": "pnpm --filter \"./packages/*\" build",
    "dev": "pnpm build:packages && pnpm --parallel --filter @paymentops/api --filter @paymentops/worker --filter @paymentops/web --filter @paymentops/provider-simulator dev",
    "db:migrate": "pnpm build:packages && pnpm --filter @paymentops/api migrate",
    "build": "pnpm -r --if-present build",
    "lint": "eslint .",
    "typecheck": "pnpm build:packages && pnpm -r --if-present typecheck && pnpm typecheck:e2e && pnpm typecheck:quality",
    "typecheck:e2e": "tsc -p tests/e2e/tsconfig.json --noEmit",
    "test": "pnpm -r --if-present test",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts",
    "format": "prettier --write .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down --remove-orphans",
    "test:contract": "vitest run --config tests/contracts/vitest.config.ts",
    "test:ui": "playwright test --config tests/playwright/playwright.config.ts",
    "test:load": "k6 run tests/load/payout-smoke.js",
    "test:load:soak": "k6 run tests/load/payout-soak.js",
    "test:smoke:staging": "node scripts/staging-smoke.mjs",
    "auth0:verify": "node scripts/verify-auth0.mjs",
    "security:audit": "pnpm audit --prod --audit-level high",
    "capture:readme": "tsx scripts/capture-readme.ts",
    "record:demo": "tsx scripts/record-demo.ts",
    "typecheck:quality": "tsc -p tests/contracts/tsconfig.json --noEmit && tsc -p tests/playwright/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@nestjs/testing": "^10.4.15",
    "@pact-foundation/pact": "^17.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.0"
  }
}
