aws_region     = "ca-central-1"
project_name   = "paymentops"
environment    = "staging"
deploy_services = false
create_database = false
use_fargate_spot = true

# Set these to the real Auth0 API settings before enabling services.
auth0_domain   = "your-tenant.us.auth0.com"
auth0_audience = "https://api.paymentops.example"

# To reuse an existing database, leave create_database=false and provide a
# Secrets Manager secret containing the complete DATABASE_URL value.
# database_url_secret_arn = "arn:aws:secretsmanager:ca-central-1:123456789012:secret:paymentops-staging/database-url-AbCdEf"

# After pushing the workspace image to the output ECR repository:
# deploy_services = true
# image_tag        = "<git-sha>"
# Dashboard Auth0 SPA client.
auth0_client_id = "your_auth0_spa_client_id"

# Production-style edge configuration. Use create_certificate=true to let
# Terraform request and DNS-validate ACM, or provide certificate_arn.
domain_name        = "paymentops.example.com"
route53_zone_id    = "Z0123456789EXAMPLE"
enable_https       = true
create_certificate = true
enable_waf         = true
alert_email        = "paymentops-alerts@example.com"
