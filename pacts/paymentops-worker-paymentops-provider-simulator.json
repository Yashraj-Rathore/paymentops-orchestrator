{
  "consumer": {
    "name": "paymentops-worker"
  },
  "interactions": [
    {
      "description": "an idempotent payout submission",
      "pending": false,
      "providerStates": [
        {
          "name": "the provider simulator accepts payouts"
        }
      ],
      "request": {
        "body": {
          "content": {
            "amountMinor": 4200,
            "callbackUrl": "http://api:3000/v1/provider-callbacks/payouts",
            "currency": "USD",
            "destinationAccount": "acct_contract",
            "payoutId": "po_contract_123",
            "tenantId": "mer_contract"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ],
          "idempotency-key": [
            "po_contract_123"
          ]
        },
        "method": "POST",
        "path": "/v1/provider/payouts"
      },
      "response": {
        "body": {
          "content": {
            "callbackDelayMs": 250,
            "providerPayoutId": "prov_contract_123",
            "status": "processing"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "status": 201
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.1"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "paymentops-provider-simulator"
  }
}